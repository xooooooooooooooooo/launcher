{
  "name": "hades-injector",
  "version": "1.14.4",
  "description": "Hades Client Launcher - Desktop App",
  "repository": {
    "type": "git",
    "url": "https://github.com/xooooooooooooooooo/launcher.git"
  },
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:start": "electron .",
    "build": "vite build",
    "build:backend": "cd backend && dotnet publish -c Release -r win-x64 --self-contained true -p:PublishAot=true -p:AssemblyName=backend -o ../dist-backend",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "package": "npm run type-check && npm run build && npm run build:backend && node -e \"require('fs').mkdirSync('build-temp', {recursive: true}); require('fs').copyFileSync('preload.js', 'build-temp/preload.js')\" && javascript-obfuscator main.js --output build-temp/main.js --compact true --control-flow-flattening true --string-array true --string-array-encoding base64 && electron-builder --config electron-builder.config.cjs"
  },
  "keywords": [
    "electron",
    "minecraft",
    "injector"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^5.3.0",
    "postcss": "^8.4.32",
    "rollup-plugin-javascript-obfuscator": "^1.0.4",
    "tailwindcss": "^3.3.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.12",
    "@supabase/supabase-js": "^2.96.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "skinview3d": "^3.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.160.0"
  }
}